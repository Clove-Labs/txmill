TXMILL_API_LISTEN=:8080

# Matches the defaults in compose.yaml — `make dev-up` then export and you're ready.
TXMILL_DB_URL=postgres://postgres:postgres@localhost:5432/txmill?sslmode=disable
TXMILL_TEST_DB_URL=postgres://postgres:postgres@localhost:5432/txmill?sslmode=disable

TXMILL_KEYSTORE_DIR=./data/keys
TXMILL_KEYSTORE_PASSWORD=change-me-32-bytes-or-more

TXMILL_DATA_DIR=./data

# Sonic mainnet defaults — override for testnet (Blaze: chain 57054, https://rpc.blaze.soniclabs.com)
TXMILL_RPC_URL=https://rpc.soniclabs.com
TXMILL_CHAIN_ID=146

TXMILL_TELEGRAM_BOT_TOKEN=
TXMILL_TELEGRAM_CHAT_ID=
TXMILL_ALERT_WEBHOOK_URL=
